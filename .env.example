# העתק ל-.env והתאם לפי הצורך.
# CHAVRUTA_PROFILE בוחר preset; כל משתנה CHAVRUTA_* עוקף שדה בודד.

# ── Docker (docker compose up --build) ───────────────────────────────────────
# הסטאק המלא (api + web) מריץ generation דרך Nebius — חובה למלא מפתח:
NEBIUS_API_KEY=your-nebius-api-key-here
# אופציונלי לעקיפה של ברירות-המחדל ב-compose:
# CHAVRUTA_LLM_MODEL=Qwen/Qwen3-32B
# CHAVRUTA_LLM_BASE_URL=https://api.studio.nebius.ai/v1
# שאר הגדרות הדוקר (profile/qdrant/db) מוזרקות ישירות ב-docker-compose.yml.

# ── Profile ──────────────────────────────────────────────────────────────────
CHAVRUTA_PROFILE=local          # local | cloud

# ── Embedding ────────────────────────────────────────────────────────────────
CHAVRUTA_EMBEDDING_MODEL=BAAI/bge-m3
CHAVRUTA_EMBEDDING_DEVICE=cpu   # cpu | cuda

# ── Vector store (Qdrant) ────────────────────────────────────────────────────
# local preset defaults: server mode via docker-compose (docker compose up -d)
# fallback to embedded: CHAVRUTA_QDRANT_MODE=embedded
CHAVRUTA_QDRANT_MODE=server
CHAVRUTA_QDRANT_URL=http://localhost:6333
# CHAVRUTA_QDRANT_PATH=data/qdrant   # used only when QDRANT_MODE=embedded
CHAVRUTA_COLLECTION=chavruta

# ── Retrieval ────────────────────────────────────────────────────────────────
CHAVRUTA_TOP_K=8
CHAVRUTA_HYBRID=false           # true = dense+sparse RRF (needs more RAM)
CHAVRUTA_RERANK=false
# CHAVRUTA_RERANK_MODEL=BAAI/bge-reranker-v2-m3
CHAVRUTA_RELEVANCE_THRESHOLD=0.3

# ── LLM — the Nebius API is the DEFAULT (the local DictaLM/Ollama backend was removed) ──────────
CHAVRUTA_LLM_BACKEND=nebius       # nebius (the API — default) | bridge (Claude in-session, no API)
CHAVRUTA_LLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
CHAVRUTA_LLM_BASE_URL=https://api.studio.nebius.ai/v1
CHAVRUTA_LLM_API_KEY=your-nebius-api-key-here   # or set NEBIUS_API_KEY above
CHAVRUTA_LLM_TEMPERATURE=0.2

# ── Query understanding ──────────────────────────────────────────────────────
# Heuristic Hebrew/landmark ref detection is always on. "llm" adds an LLM fallback, but it
# hallucinated wrong refs on this corpus — keep "heuristic".
CHAVRUTA_QUERY_PLANNER=heuristic  # heuristic | llm
# NEBIUS_API_KEY=your-nebius-api-key-here   # alias — picked up automatically

# ── Qdrant Cloud — required when CHAVRUTA_PROFILE=cloud ──────────────────────
# Create a free cluster at https://cloud.qdrant.io
# CHAVRUTA_QDRANT_API_KEY=your-qdrant-api-key-here
# CHAVRUTA_QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333

# ── Ingest Job overrides (scripts/ingest_job.py — the RAG "factory") ─────────
# INGEST_BOOKS=Genesis,Exodus        # subset of books for the Sefaria fallback
# INGEST_BATCH=64                    # embedding batch size (GPU jobs: try 128)
# INGEST_CHUNKS_PATH=data/processed/all_chunks_full.json  # reuse local corpus, skip fetch
#
# Corpus source: pull the prebuilt corpus from HF (recommended over a live Sefaria fetch)
# INGEST_CORPUS_HF_REPO=your-user/chavruta-corpus
# INGEST_CORPUS_HF_FILE=all_chunks_full.json
#
# Publish the prebuilt index to HF — the artifact end users download (bootstrap_rag.py)
# INGEST_INDEX_HF_REPO=your-user/chavruta-index
# HF_TOKEN=your-hf-write-token       # required to publish the index (and for private repos)
