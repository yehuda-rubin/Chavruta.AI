# Chavruta.AI — frontend image (React + Vite build, served by nginx).
#
# Build context is the repo root:
#   docker build -f docker/Dockerfile.web -t chavruta-web:latest .
#
# Served via docker-compose (service `web`); nginx reverse-proxies /api → api:8080.

# ── Stage 1: build the SPA ──────────────────────────────────────────────────
FROM node:22-alpine AS build

WORKDIR /app
COPY app/frontend/package.json app/frontend/package-lock.json* ./
RUN npm ci

COPY app/frontend/ ./
RUN npm run build

# ── Stage 2: serve static assets ─────────────────────────────────────────────
FROM nginx:1.27-alpine

COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
